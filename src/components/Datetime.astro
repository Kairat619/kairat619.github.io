---
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { SITE } from "@/config";
import { formatDate, useTranslations } from "@/i18n/ui";
import { getLocaleFromPathname } from "@/i18n/utils";

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
} = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const t = useTranslations(locale);
const resolvedTimeZone = postTimezone || SITE.timezone;

/* ========== Formatted Datetime ========== */
const isModified = modDatetime && modDatetime > pubDatetime;

const datetime = new Date(isModified ? modDatetime : pubDatetime);
const date = formatDate(datetime, locale, resolvedTimeZone);
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  {
    isModified && (
      <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
        {t.updated}
      </span>
    )
  }
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={datetime.toISOString()}>{date}</time
  >
</div>
