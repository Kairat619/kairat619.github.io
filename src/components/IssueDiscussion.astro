---
type Props = {
  href: string;
  title: string;
  description: string;
  ctaLabel: string;
};

const { href, title, description, ctaLabel } = Astro.props;
---

<section
  class="mt-8 rounded-2xl border border-accent/20 bg-accent/5 px-5 py-4"
  aria-labelledby="issue-discussion-title"
>
  <h2 id="issue-discussion-title" class="text-lg font-semibold text-accent">
    {title}
  </h2>
  <p class="mt-2 text-sm leading-6 text-foreground/85">{description}</p>
  <a
    href={href}
    class="mt-4 inline-flex items-center rounded-full border border-accent/30 px-4 py-2 text-sm font-medium text-accent transition hover:bg-accent/10"
    target="_blank"
    rel="noreferrer"
  >
    {ctaLabel}
  </a>
</section>
