---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { SITE } from "@/config";
import { useTranslations } from "@/i18n/ui";
import {
  getLocaleFromPathname,
  localizePath,
  stripLocaleFromPathname,
} from "@/i18n/utils";

const { pathname } = Astro.url;
const locale = getLocaleFromPathname(pathname);
const t = useTranslations(locale);

// Remove trailing slash from current pathname if exists
const currentPath = stripLocaleFromPathname(
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname
);

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  {t.skipToContent}
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href={localizePath("/", locale)}
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label={t.openMenu}
        aria-expanded="false"
        aria-controls="menu-items"
        data-open-label={t.openMenu}
        data-close-label={t.closeMenu}
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-44 grid-cols-2 place-content-center gap-2",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <a
            href={localizePath("/posts", locale)}
            class:list={{ "active-nav": isActive("/posts") }}
          >
            {t.posts}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={localizePath("/tags", locale)}
            class:list={{ "active-nav": isActive("/tags") }}
          >
            {t.tags}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={localizePath("/about", locale)}
            class:list={{ "active-nav": isActive("/about") }}
          >
            {t.about}
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href={localizePath("/archives", locale)}
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title={t.archives}
                aria-label={t.archives}
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">{t.archives}</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-2 flex items-center justify-center sm:col-span-1">
          <LanguageSwitcher />
        </li>
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href={localizePath("/search", locale)}
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title={t.search}
            aria-label={t.search}
          >
            <IconSearch />
            <span class="sr-only">{t.search}</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;
    if (menuBtn.dataset.bound === "true") return;

    menuBtn.dataset.bound = "true";

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
      const openLabel = menuBtn.getAttribute("data-open-label") || "Open Menu";
      const closeLabel =
        menuBtn.getAttribute("data-close-label") || "Close Menu";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? openLabel : closeLabel);

      menuItems.classList.toggle("hidden", openMenu);
      menuIcon.classList.toggle("hidden", !openMenu);
      closeIcon.classList.toggle("hidden", openMenu);
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
